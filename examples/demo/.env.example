# ===== Required =====
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id
APP_BASE_URL=http://localhost:3000
AUTH0_SESSION_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# ===== Optional (choose auth method) =====
# Option A: Client secret (default)
AUTH0_CLIENT_SECRET=your_client_secret

# Option B: JWT Client Assertion (private_key_jwt)
# Generate with: npm run gen-keypair
# AUTH0_CLIENT_ASSERTION_SIGNING_KEY=base64-encoded-pkcs8-pem
# AUTH0_CLIENT_ASSERTION_SIGNING_ALG=RS256

# ===== Optional Features (Confidential Client) =====
# Enable Pushed Authorization Requests (PAR)
# AUTH0_PUSHED_AUTHORIZATION_REQUESTS=false
